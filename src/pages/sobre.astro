---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Footer from "../components/Footer.astro";
import StructureGallery from "../components/StructureGallery.astro";
import DiagnosticCTA from "../components/DiagnosticCTA.astro";
import {
    Heart,
    Target,
    Clock,
    ShieldCheck,
    CheckCircle2,
    ArrowRight,
} from "lucide-react";

const doctors = [
    {
        name: "Dr. Roberto Silva",
        role: "Diretor Técnico & Cirurgia Geral",
        image: "https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?q=80&w=2070&auto=format&fit=crop",
    },
    {
        name: "Dra. Ana Bittencourt",
        role: "Anestesiologista Chefe",
        image: "https://images.unsplash.com/photo-1594824436998-d8bb49f42b32?q=80&w=2070&auto=format&fit=crop",
    },
    {
        name: "Dr. Carlos Mendes",
        role: "Ortopedia e Traumatologia",
        image: "https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=2064&auto=format&fit=crop",
    },
];

const values = [
    {
        title: "Cuidado Humanizado",
        desc: "Cada paciente é único. Do pré-operatório à alta, nossa equipe está focada no seu conforto físico e emocional.",
        icon: Heart,
    },
    {
        title: "Segurança Nível Global",
        desc: "Protocolos rigorosos e estrutura de ponta convergem para tornar nossas cirurgias altamente seguras.",
        icon: ShieldCheck,
    },
    {
        title: "Integração Total",
        desc: "Uma jornada sem atritos. Seus exames e histórico fluem perfeitamente do Centro de Diagnóstico para o Centro Cirúrgico.",
        icon: Target,
    },
];
---

<Layout title="Sobre Nós | Hospital São Lucas - Marau, RS">
    <main class="bg-surface-gray min-h-screen pt-24 lg:pt-0">
        {/* Hero Premium Section */}
        <section
            class="relative min-h-[70vh] flex items-center pt-24 lg:pt-32 pb-20 overflow-hidden bg-medical-dark rounded-b-[48px] lg:rounded-b-[80px]"
        >
            {/* Background Elements */}
            <div class="absolute inset-0 z-0">
                <img
                    src="https://images.unsplash.com/photo-1551076805-e18690c5e561?q=80&w=2070&auto=format&fit=crop"
                    alt="Estrutura de excelência"
                    class="w-full h-full object-cover object-center opacity-40 mix-blend-overlay"
                />
                <div
                    class="absolute inset-0 bg-gradient-to-r from-medical-dark via-medical-dark/90 to-transparent"
                >
                </div>
            </div>

            <div class="container mx-auto px-6 md:px-12 relative z-10">
                <div class="max-w-3xl">
                    <span
                        class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white text-sm font-bold tracking-wider px-4 py-2 rounded-full mb-8 backdrop-blur-md"
                    >
                        <span
                            class="w-2 h-2 rounded-full bg-medical-accent animate-pulse"
                        ></span>
                        A História do São Lucas
                    </span>
                    <h1
                        class="text-5xl md:text-7xl font-bold text-white font-heading leading-[1.1] mb-8"
                    >
                        Elevando o padrão <br />
                        <span
                            class="text-medical-light italic font-serif opacity-90"
                            >de cuidado e vida.</span
                        >
                    </h1>
                    <p
                        class="text-xl text-blue-100/90 leading-relaxed max-w-2xl mb-10"
                    >
                        O Hospital São Lucas não é apenas uma estrutura moderna.
                        É a materialização de uma filosofia onde a excelência
                        médica encontra o conforto, garantindo procedimentos
                        seguros com a tranquilidade que você merece.
                    </p>
                </div>
            </div>
        </section>

        {
            /* The "Hospital Dia" Paradigm - Image Left, Text Right, Organic overlapping */
        }
        <section class="py-24 md:py-32 relative">
            <div class="container mx-auto px-6 md:px-12">
                <div class="flex flex-col lg:flex-row gap-16 items-center">
                    {/* Visual Side */}
                    <div class="w-full lg:w-1/2 relative">
                        <div
                            class="aspect-[4/5] rounded-[32px] overflow-hidden relative"
                        >
                            <img
                                src="https://images.unsplash.com/photo-1638202993928-7267aad84c31?q=80&w=1974&auto=format&fit=crop"
                                alt="Médico conversando com paciente"
                                class="w-full h-full object-cover"
                            />
                            <div
                                class="absolute inset-0 border-4 border-white/20 rounded-[32px] m-4"
                            >
                            </div>
                        </div>

                        {/* Floating Card */}
                        <div
                            class="absolute -bottom-10 -right-4 md:-right-10 bg-white p-6 md:p-8 rounded-3xl shadow-2xl border border-gray-100 max-w-[280px] z-20"
                        >
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="w-12 h-12 rounded-full bg-medical-blue/10 text-medical-blue flex items-center justify-center"
                                >
                                    <Clock size={24} />
                                </div>
                                <h4
                                    class="font-bold text-medical-dark text-xl leading-tight"
                                >
                                    Máximo de 12h
                                </h4>
                            </div>
                            <p class="text-slate-600 text-sm">
                                Tempo de internação otimizado para que sua
                                recuperação aconteça no aconchego de sua casa.
                            </p>
                        </div>
                    </div>

                    {/* Text Side */}
                    <div class="w-full lg:w-1/2 lg:pl-10">
                        <h2
                            class="text-sm text-medical-blue font-bold uppercase tracking-widest mb-4"
                        >
                            Novo Paradigma
                        </h2>
                        <h3
                            class="text-4xl md:text-5xl font-bold font-heading text-medical-dark mb-8 leading-tight"
                        >
                            Por que escolher o <br />modelo Hospital Dia?
                        </h3>

                        <div class="prose prose-lg text-slate-600 mb-8">
                            <p>
                                Nossa jornada começou com o sucesso do Centro de
                                Diagnóstico, onde provamos que <strong
                                    >agilidade não precisa excluir a empatia</strong
                                >. Trouxemos essa mesma visão para o nosso
                                centro cirúrgico.
                            </p>
                            <p>
                                O ambiente hospitalar tradicional pode ser
                                massivo e estressante. No Hospital São Lucas,
                                focamos em procedimentos de curta permanência.
                                Isso significa um <strong
                                    >fluxo inteligente, previsibilidade total e
                                    um contato muito mais íntimo e direto</strong
                                > entre equipe médica e paciente.
                            </p>
                        </div>

                        <ul class="space-y-4 mb-10">
                            {
                                [
                                    "Ambientes desenhados para reduzir a tensão pré-cirúrgica.",
                                    "Estrutura dedicada para minimizar riscos e infecções.",
                                    "Agilidade que respeita o seu tempo e o da sua família.",
                                    "Conexão direta com exames de alta precisão.",
                                ].map((item) => (
                                    <li class="flex items-start gap-3">
                                        <CheckCircle2
                                            class="text-medical-accent shrink-0 mt-1"
                                            size={20}
                                        />
                                        <span class="text-slate-700 font-medium">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        {/* Bento Grid Values Section */}
        <section class="py-24 bg-white relative">
            <div
                class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"
            >
            </div>
            <div class="container mx-auto px-6 md:px-12">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <h2
                        class="text-3xl md:text-5xl font-bold text-medical-dark font-heading mb-6"
                    >
                        Nossos Pilares
                    </h2>
                    <p class="text-lg text-slate-500">
                        Tudo o que construímos se baseia nestes três alicerces
                        inegociáveis. Eles ditam nosso padrão de infraestrutura,
                        quadro clínico e atendimento.
                    </p>
                </div>

                <div
                    class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto"
                >
                    {
                        values.map((v, i) => (
                            <div class="bg-surface-gray rounded-[2rem] p-10 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                                <div class="w-14 h-14 bg-white rounded-2xl shadow-sm text-medical-blue flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
                                    <v.icon size={28} />
                                </div>
                                <h3 class="text-2xl font-bold text-medical-dark mb-4">
                                    {v.title}
                                </h3>
                                <p class="text-slate-600 leading-relaxed">
                                    {v.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        {/* Medical Team Teaser */}
        <section class="py-32 bg-medical-dark relative overflow-hidden">
            <div
                class="absolute -top-40 -left-40 w-96 h-96 bg-medical-blue rounded-full mix-blend-multiply filter blur-[128px] opacity-40"
            >
            </div>
            <div
                class="absolute -bottom-40 -right-40 w-96 h-96 bg-medical-accent rounded-full mix-blend-multiply filter blur-[128px] opacity-20"
            >
            </div>

            <div class="container mx-auto px-6 md:px-12 relative z-10">
                <div
                    class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8"
                >
                    <div class="max-w-2xl">
                        <h2
                            class="text-medical-light font-bold tracking-widest text-sm uppercase mb-4"
                        >
                            O Fator Humano
                        </h2>
                        <h3
                            class="text-4xl md:text-5xl font-heading font-bold text-white leading-tight"
                        >
                            Mentes brilhantes, <br />
                            <span class="text-blue-200 font-serif italic"
                                >corações dedicados.</span
                            >
                        </h3>
                    </div>
                    <a
                        href="/especialidades"
                        class="group inline-flex items-center gap-3 text-white font-bold bg-white/10 hover:bg-white/20 border border-white/20 px-8 py-4 rounded-full transition-all"
                    >
                        Todas as Especialidades
                        <ArrowRight
                            size={20}
                            class="group-hover:translate-x-1 transition-transform"
                        />
                    </a>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    {
                        doctors.map((doc) => (
                            <div class="group cursor-pointer">
                                <div class="aspect-[3/4] rounded-3xl overflow-hidden mb-6 relative">
                                    <img
                                        src={doc.image}
                                        alt={doc.name}
                                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                    />
                                    <div class="absolute inset-0 bg-gradient-to-t from-medical-dark/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                                        <div class="text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                            <p class="font-bold text-sm text-medical-accent mb-1">
                                                Ver perfil
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <h4 class="text-2xl font-bold text-white mb-2">
                                    {doc.name}
                                </h4>
                                <p class="text-medical-light font-medium">
                                    {doc.role}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </section>

        {/* Existing Components */}
        <div class="bg-surface-gray py-12">
            <StructureGallery />
        </div>

        <DiagnosticCTA />
    </main>
</Layout>
