---
import Layout from "../layouts/Layout.astro";
import { Phone, Mail, MapPin, MessageCircle, Info, Send, HeartHandshake, Headphones } from "lucide-react";
---

<Layout title="Ouvidoria / SAC - Hospital São Lucas">
  <main class="bg-surface-gray min-h-screen">
    {/* Hero Section */}
    <div class="relative h-[450px] w-full overflow-hidden flex items-center bg-medical-dark">
      <div class="absolute inset-0 bg-[#073a78] opacity-60 z-[1]"></div>
      <img 
        src="https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80&w=2070" 
        alt="Atendimento Hospital São Lucas" 
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="container mx-auto px-6 relative z-10">
        <div class="mb-8">
            <img 
                src="/images/logo-h-branco.png" 
                alt="Hospital São Lucas" 
                class="h-16 w-auto"
            />
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-4 drop-shadow-xl">
          Canais de<br/><span class="text-medical-accent">Atendimento</span>
        </h1>
        <div class="w-32 h-2 bg-medical-accent rounded-full"></div>
      </div>
    </div>

    <div class="container mx-auto px-6 py-16">
      <div class="flex flex-col lg:flex-row gap-12">
        
        {/* Main Content */}
        <div class="w-full lg:w-2/3">
          <div class="bg-white rounded-[2.5rem] shadow-xl p-8 md:p-16 space-y-12">
            
            <section class="space-y-6">
              <div class="flex items-center gap-4 text-[#073a78]">
                <Headphones size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Ouvidoria / SAC</h2>
              </div>
              <p class="text-lg text-slate-600 leading-relaxed">
                Seja para obter informações sobre nossos serviços ou registrar uma denúncia, elogio ou sugestão, o <strong>Hospital São Lucas</strong> está pronto para ajudar. Valorizamos seu feedback e nos comprometemos a resolver qualquer questão com transparência, humanização e eficiência.
              </p>
            </section>

            <section class="space-y-8 border-t border-slate-100 pt-10">
              <div class="flex items-center gap-4 text-[#073a78]">
                <MessageCircle size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Fale Conosco</h2>
              </div>
              
              <form class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-sm font-bold text-slate-700 ml-2">Nome Completo</label>
                  <input 
                    type="text" 
                    placeholder="Digite aqui seu nome"
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-medical-blue focus:bg-white transition-all outline-none"
                  />
                </div>
                <div class="space-y-2">
                  <label class="text-sm font-bold text-slate-700 ml-2">E-mail</label>
                  <input 
                    type="email" 
                    placeholder="Digite aqui seu e-mail"
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-medical-blue focus:bg-white transition-all outline-none"
                  />
                </div>
                <div class="space-y-2">
                  <label class="text-sm font-bold text-slate-700 ml-2">Telefone / WhatsApp</label>
                  <input 
                    type="tel" 
                    placeholder="(00) 00000-0000"
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-medical-blue focus:bg-white transition-all outline-none"
                  />
                </div>
                <div class="space-y-2">
                  <label class="text-sm font-bold text-slate-700 ml-2">Assunto</label>
                  <select class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-medical-blue focus:bg-white transition-all outline-none appearance-none">
                    <option value="">Selecione um assunto</option>
                    <option value="elogio">Elogio</option>
                    <option value="sugestao">Sugestão</option>
                    <option value="reclamacao">Reclamação</option>
                    <option value="informacao">Pedido de Informação</option>
                  </select>
                </div>
                <div class="md:col-span-2 space-y-2">
                  <label class="text-sm font-bold text-slate-700 ml-2">Sua Mensagem</label>
                  <textarea 
                    rows="5" 
                    placeholder="Como podemos ajudar você hoje?"
                    class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-medical-blue focus:bg-white transition-all outline-none resize-none"
                  ></textarea>
                </div>
                
                <div class="md:col-span-2 flex items-start gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                  <input type="checkbox" id="lgpd" class="mt-1 w-5 h-5 rounded border-slate-300 text-medical-blue focus:ring-medical-blue" />
                  <label for="lgpd" class="text-sm text-slate-500 leading-tight">
                    Eu concordo que o <strong>Hospital São Lucas</strong> armazene minhas informações enviadas para que possam entrar em contato e responder à minha solicitação, conforme a nossa Política de Privacidade.
                  </label>
                </div>

                <div class="md:col-span-2 pt-4">
                  <button class="w-full md:w-auto bg-medical-blue text-white px-10 py-4 rounded-2xl font-black text-lg hover:bg-medical-dark transition-all shadow-xl hover:shadow-medical-blue/20 flex items-center justify-center gap-3">
                    <Send size={20} />
                    Enviar Mensagem
                  </button>
                </div>
              </form>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <div class="flex items-center gap-4 text-[#073a78]">
                <HeartHandshake size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Nossos Compromissos</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                  <h4 class="font-bold text-medical-blue mb-2">Humanização</h4>
                  <p class="text-sm text-slate-500">Cada contato é tratado com empatia e respeito, priorizando o bem-estar do paciente.</p>
                </div>
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                  <h4 class="font-bold text-medical-blue mb-2">Transparência</h4>
                  <p class="text-sm text-slate-500">Informações claras e processos abertos para garantir a confiança em nosso atendimento.</p>
                </div>
              </div>
            </section>
          </div>
        </div>

        {/* Sidebar */}
        <aside class="w-full lg:w-1/3 space-y-8">
          <div class="bg-white rounded-[2rem] shadow-lg p-8">
            <h3 class="text-2xl font-black text-[#073a78] mb-6 border-b border-slate-100 pb-4">Contatos Diretos</h3>
            <div class="space-y-6">
               <div class="flex items-start gap-4">
                  <div class="bg-medical-accent/10 p-3 rounded-xl">
                    <Phone size={24} className="text-medical-accent" />
                  </div>
                  <div>
                    <h5 class="font-bold text-slate-800">Telefones</h5>
                    <p class="text-slate-500">(54) 3342-9292</p>
                    <p class="text-slate-500">(54) 3342-9206</p>
                  </div>
               </div>

               <div class="flex items-start gap-4">
                  <div class="bg-medical-accent/10 p-3 rounded-xl">
                    <MessageCircle size={24} className="text-medical-accent" />
                  </div>
                  <div>
                    <h5 class="font-bold text-slate-800">WhatsApp</h5>
                    <p class="text-slate-500">(54) 3342-9292</p>
                  </div>
               </div>

               <div class="flex items-start gap-4">
                  <div class="bg-medical-accent/10 p-3 rounded-xl">
                    <MapPin size={24} className="text-medical-accent" />
                  </div>
                  <div>
                    <h5 class="font-bold text-slate-800">Endereço</h5>
                    <p class="text-slate-500 leading-tight">Avenida Barão do Rio Branco, 1751, Marau – RS</p>
                  </div>
               </div>

               <div class="flex items-start gap-4 pt-4 border-t border-slate-100">
                  <div class="bg-slate-100 p-3 rounded-xl">
                    <Info size={24} className="text-slate-400" />
                  </div>
                  <div>
                    <h5 class="font-bold text-slate-800">Horário</h5>
                    <p class="text-sm text-slate-500">Seg. à Sex.: 07h às 19h</p>
                    <p class="text-sm text-slate-500">Sáb.: 08h às 12h</p>
                  </div>
               </div>
            </div>
          </div>

          <div class="bg-medical-dark rounded-[2rem] overflow-hidden p-8 text-center text-white relative">
             <div class="absolute inset-0 opacity-20 pointer-events-none">
                <img 
                    src="/images/logo-h-branco.png" 
                    class="w-full h-full object-contain p-10 grayscale brightness-200"
                />
             </div>
             <div class="relative z-10">
                <h4 class="text-2xl font-black mb-6 leading-tight">Agendamento Online</h4>
                <p class="text-sm opacity-80 mb-8">Precisa marcar um exame ou consulta agora? Use nosso canal direto via WhatsApp.</p>
                <a href="https://wa.me/5433429292" target="_blank" class="block w-full bg-medical-accent text-white px-6 py-4 rounded-2xl font-bold hover:bg-white hover:text-medical-blue transition-all shadow-lg hover:shadow-cyan-500/20">
                    Falar com Atendente
                </a>
             </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>
