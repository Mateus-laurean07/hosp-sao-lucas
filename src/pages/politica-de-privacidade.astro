---
import Layout from "../layouts/Layout.astro";
import { Phone, Mail, MapPin, ShieldCheck, FileText, UserCheck, Lock } from "lucide-react";
---

<Layout title="Política de Privacidade - Hospital São Lucas">
  <main class="bg-surface-gray min-h-screen">
    {/* Hero Section */}
    <div class="relative h-[450px] w-full overflow-hidden flex items-center bg-medical-dark">
      <div class="absolute inset-0 bg-[#073a78] opacity-60 z-[1]"></div>
      <img 
        src="https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&q=80&w=2070" 
        alt="Privacidade e Segurança Hospital São Lucas" 
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="container mx-auto px-6 relative z-10">
        <div class="mb-8">
            <img 
                src="/images/logo-h-branco.png" 
                alt="Hospital São Lucas" 
                class="h-16 w-auto"
            />
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-4 drop-shadow-xl">
          Política de<br/><span class="text-medical-accent">Privacidade</span>
        </h1>
        <div class="w-32 h-2 bg-medical-accent rounded-full"></div>
      </div>
    </div>

    <div class="container mx-auto px-6 py-16">
      <div class="flex flex-col lg:flex-row gap-12">
        
        {/* Main Content */}
        <div class="w-full lg:w-2/3">
          <div class="bg-white rounded-[2.5rem] shadow-xl p-8 md:p-16 space-y-12">
            
            <section class="space-y-6">
              <div class="flex items-center gap-4 text-[#073a78]">
                <ShieldCheck size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Introdução</h2>
              </div>
              <p class="text-lg text-slate-600 leading-relaxed">
                O <strong>Hospital São Lucas</strong> possui sua sede na cidade de Marau, RS. Mantemos o compromisso com a proteção e respeito à privacidade e proteção dos seus dados pessoais, respeitando a LGPD (Lei nº 13.709/2018). Esta política descreve como coletamos e protegemos suas informações em todos os nossos canais.
              </p>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <div class="flex items-center gap-4 text-[#073a78]">
                <FileText size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Definições LGPD</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                  <h4 class="font-bold text-[#0b5bbb] mb-2">Dados Pessoais</h4>
                  <p class="text-sm text-slate-500">Informação relacionada a pessoa natural identificada ou identificável.</p>
                </div>
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
                  <h4 class="font-bold text-[#0b5bbb] mb-2">Dados Sensíveis</h4>
                  <p class="text-sm text-slate-500">Dados sobre saúde, origem racial, convicção religiosa, entre outros.</p>
                </div>
              </div>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <div class="flex items-center gap-4 text-[#073a78]">
                <Lock size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Finalidade do Tratamento</h2>
              </div>
              <p class="text-lg text-slate-600 leading-relaxed">
                Tratamos seus dados para a prestação de serviços médico-hospitalares, diagnóstico por imagem, agendamentos, faturamento de convênios e cumprimento de obrigações legais e regulatórias do setor de saúde.
              </p>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <div class="flex items-center gap-4 text-[#073a78]">
                <UserCheck size={32} className="text-medical-blue" />
                <h2 class="text-3xl font-black">Dados Coletados</h2>
              </div>
              <ul class="space-y-4 text-lg text-slate-600">
                <li class="flex items-start gap-3 italic">
                  <span class="text-medical-accent font-bold">•</span>
                  <span><strong>Cadastro:</strong> Nome, CPF, RG, nascimento, endereço e plano de saúde.</span>
                </li>
                <li class="flex items-start gap-3 italic">
                  <span class="text-medical-accent font-bold">•</span>
                  <span><strong>Saúde:</strong> Requisições médicas, histórico clínico e resultados de exames.</span>
                </li>
              </ul>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <h2 class="text-3xl font-black text-[#073a78]">Canais de Atendimento</h2>
              <p class="text-lg text-slate-600 leading-relaxed">
                Utilizamos canais oficiais como Telefone, WhatsApp e E-mail para facilitar seu agendamento e esclarecer dúvidas, sempre respeitando a segurança da informação.
              </p>
            </section>

            <section class="space-y-6 border-t border-slate-100 pt-10">
              <h2 class="text-3xl font-black text-[#073a78]">Encarregado de Dados (DPO)</h2>
              <div class="bg-medical-dark p-8 rounded-3xl text-white">
                <p class="mb-4 opacity-80">Para dúvidas sobre privacidade, entre em contato:</p>
                <div class="flex flex-col gap-3">
                  <div class="flex items-center gap-3">
                    <Mail size={18} className="text-medical-accent" />
                    <span class="font-bold">privacidade@hsaolucas.com.br</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <Phone size={18} className="text-medical-accent" />
                    <span class="font-bold">(54) 3342-9292</span>
                  </div>
                </div>
              </div>
            </section>
          </div>
        </div>

        {/* Sidebar */}
        <aside class="w-full lg:w-1/3 space-y-8">
          <div class="bg-white rounded-[2rem] shadow-lg p-8">
            <h3 class="text-2xl font-black text-[#073a78] mb-6 border-b border-slate-100 pb-4">Acesso Rápido</h3>
            <ul class="space-y-4">
              <li>
                <a href="/" class="text-slate-500 hover:text-medical-blue font-bold flex items-center gap-2 transition-colors">
                  <span class="text-medical-accent">></span> Voltar ao Início
                </a>
              </li>
              <li>
                <a href="#especialidades" class="text-slate-500 hover:text-medical-blue font-bold flex items-center gap-2 transition-colors">
                  <span class="text-medical-accent">></span> Nossos Médicos
                </a>
              </li>
              <li>
                <a href="https://pacs.centrodediagnostico.com.br/login" target="_blank" class="text-slate-500 hover:text-medical-blue font-bold flex items-center gap-2 transition-colors">
                  <span class="text-medical-accent">></span> Resultado de Exames
                </a>
              </li>
            </ul>
          </div>

          <div class="relative rounded-[2rem] overflow-hidden group h-[320px] bg-medical-dark flex flex-col items-center justify-center p-8 text-center">
             <div class="absolute inset-0 opacity-20">
                <img 
                    src="/images/logo-h-branco.png" 
                    class="w-full h-full object-contain p-10 grayscale brightness-200"
                />
             </div>
             <div class="relative z-10">
                <h4 class="text-2xl font-black mb-6 leading-tight text-white">Pronto para cuidar da sua saúde?</h4>
                <a href="https://wa.me/5433429292" target="_blank" class="block w-full bg-medical-accent text-white px-6 py-4 rounded-2xl font-bold hover:bg-white hover:text-medical-blue transition-all shadow-lg hover:shadow-cyan-500/20">
                    Agendar Agora
                </a>
             </div>
          </div>
        </aside>
      </div>
    </div>
  </main>
</Layout>
