---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorAdmin from "../../components/DoctorAdmin.tsx";

// Proteção de rota no lado do servidor
const session = Astro.cookies.get('hosp_admin_session');

if (!session || session.value !== 'active') {
  return Astro.redirect('/admin');
}
---

<Layout title="Administração - Hosp São Lucas">
  <main class="w-full min-h-screen bg-surface-gray">
    <div>
      <DoctorAdmin client:load />
    </div>
  </main>
</Layout>
