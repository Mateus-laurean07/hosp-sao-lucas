---
import Layout from "../../layouts/Layout.astro";
import { StethoscopeOutline } from 'healthicons-react';
---

<Layout title="Registrar Administrador - Hospital São Lucas">
  <main class="min-h-screen bg-[#f3f7fb] flex items-center justify-center p-4 font-sans">
    <div 
        id="register-card"
        class="bg-white w-full max-w-5xl rounded-[2.5rem] shadow-2xl overflow-hidden flex flex-col md:flex-row min-h-[600px] transition-all duration-500"
    >
        {/* Lado Esquerdo - Info */}
        <div class="w-full md:w-1/2 p-12 md:p-16 flex flex-col justify-center bg-white">
            <div class="flex items-center gap-3 mb-10">
                <div class="w-16 h-16 bg-[#0b5bbb] rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/20">
                    <StethoscopeOutline className="w-10 h-10 text-white fill-current" />
                </div>
                <div>
                    <h1 class="text-2xl font-black text-[#073a78] leading-none">Hospital</h1>
                    <h1 class="text-3xl font-black text-[#0b5bbb] leading-tight">São Lucas</h1>
                </div>
            </div>

            <h2 class="text-4xl md:text-5xl font-black text-[#073a78] mb-6 leading-tight tracking-tight">
                Crie seu Acesso Administrador
            </h2>
            <p class="text-slate-500 text-lg leading-relaxed font-medium max-w-sm">
                Cadastre seu e-mail e crie sua senha para gerenciar os profissionais do hospital.
            </p>
        </div>

        {/* Lado Direito - Formulário */}
        <div class="w-full md:w-1/2 bg-[#e8f1f9] p-8 md:p-16 flex flex-col justify-center items-center">
            <div class="w-full max-w-sm bg-white rounded-[2rem] p-8 md:p-10 shadow-xl relative">
                
                {/* Passo 1: E-mail Inicial */}
                <div id="step-1">
                    <h3 class="text-3xl font-black text-[#073a78] mb-8">Passo 1</h3>
                    <form id="form-step-1" class="space-y-6">
                        <div class="space-y-2">
                            <label class="flex items-center gap-2 text-[11px] font-black uppercase text-slate-400 tracking-wider ml-1">
                                SEU MELHOR E-MAIL
                            </label>
                            <input 
                                type="email" 
                                id="reg-email-1"
                                required
                                class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#0b5bbb] focus:bg-white outline-none transition-all font-bold text-slate-700"
                                placeholder="exemplo@gmail.com"
                            />
                        </div>
                        <button 
                            type="submit" 
                            class="w-full py-5 bg-[#2b6fcb] text-white font-black rounded-2xl shadow-xl shadow-blue-500/20 hover:bg-[#073a78] transition-all uppercase tracking-[0.15em] text-sm"
                        >
                            Próximo Passo
                        </button>
                    </form>
                </div>

                {/* Passo 2: Confirmar E-mail e Criar Senha */}
                <div id="step-2" class="hidden">
                    <h3 class="text-3xl font-black text-[#073a78] mb-8">Passo 2</h3>
                    <form id="form-step-2" class="space-y-6">
                        <div class="space-y-2">
                            <label class="flex items-center gap-2 text-[11px] font-black uppercase text-slate-400 tracking-wider ml-1">
                                CONFIRME SEU E-MAIL
                            </label>
                            <input 
                                type="email" 
                                id="reg-email-2"
                                required
                                class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#0b5bbb] focus:bg-white outline-none transition-all font-bold text-slate-700"
                                placeholder="exemplo@gmail.com"
                            />
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-center gap-2 text-[11px] font-black uppercase text-slate-400 tracking-wider ml-1">
                                CRIE SUA SENHA
                            </label>
                            <input 
                                type="password" 
                                id="reg-password"
                                required
                                minlength="6"
                                class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-[#0b5bbb] focus:bg-white outline-none transition-all font-bold text-slate-700"
                                placeholder="Mínimo 6 caracteres"
                            />
                        </div>
                        <button 
                            type="submit" 
                            class="w-full py-5 bg-[#2b6fcb] text-white font-black rounded-2xl shadow-xl shadow-blue-500/20 hover:bg-[#073a78] transition-all uppercase tracking-[0.15em] text-sm"
                        >
                            Finalizar Cadastro
                        </button>
                    </form>
                </div>

                <div id="reg-message" class="hidden mt-6 bg-red-50 text-red-600 p-4 rounded-xl text-xs font-bold text-center border border-red-100">
                </div>
            </div>
        </div>
    </div>
  </main>

  <script>
    const step1 = document.getElementById('step-1');
    const step2 = document.getElementById('step-2');
    const form1 = document.getElementById('form-step-1');
    const form2 = document.getElementById('form-step-2');
    const regMessage = document.getElementById('reg-message');
    const emailInput1 = document.getElementById('reg-email-1') as HTMLInputElement;
    const emailInput2 = document.getElementById('reg-email-2') as HTMLInputElement;
    
    form1?.addEventListener('submit', (e) => {
        e.preventDefault();
        emailInput2.value = emailInput1.value; // Pré-preenche o segundo passo
        step1?.classList.add('hidden');
        step2?.classList.remove('hidden');
    });

    form2?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email2 = emailInput2.value;
        const password = (document.getElementById('reg-password') as HTMLInputElement).value;

        if (email2 !== emailInput1.value) {
            if (regMessage) {
                regMessage.innerText = "Os e-mails nos dois passos devem ser iguais!";
                regMessage.classList.remove('hidden');
            }
            return;
        }

        if (regMessage) {
            regMessage.innerText = "Salvando seu acesso...";
            regMessage.classList.remove('hidden', 'bg-red-50', 'text-red-600', 'border-red-100');
            regMessage.classList.add('bg-green-50', 'text-green-600', 'border-green-100');
        }

        // Salva no localStorage para o login usar
        const adminUser = { email: email2, password: password };
        localStorage.setItem('hosp_admin_user', JSON.stringify(adminUser));
        
        setTimeout(() => {
            window.location.href = '/admin';
        }, 1500);
    });
  </script>
</Layout>
