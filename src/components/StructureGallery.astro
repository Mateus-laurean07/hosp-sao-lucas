---
import { Camera } from "lucide-react";
import infusionImg from "../assets/images/3.JPG.jpeg";
import receptionImg from "../assets/images/IMG_4201.JPG";
import surgeryNewImg from "../assets/images/1.JPG.jpeg";
import suiteImg from "../assets/images/2.JPG.jpeg";
import techImg from "../assets/images/IMG_4287.JPG";
import socialImg from "../assets/images/IMG_4213.JPG";
import sterileImg from "../assets/images/IMG_4311.JPG";
import extraImg from "../assets/images/IMG_4271.JPG (1).jpeg";

const structureImages = [
    {
        url: receptionImg.src,
        alt: "Recepção e Acolhimento",
        className: "md:col-span-2 md:row-span-2",
        title: "Recepção",
        description: "Ambiente moderno e acolhedor para o seu primeiro contato",
    },
    {
        url: surgeryNewImg.src,
        alt: "Centro Cirúrgico Avançado",
        className: "md:col-span-1 md:row-span-1",
        title: "Tecnologia",
        description: "Equipamentos de última geração para sua segurança",
    },
    {
        url: sterileImg.src,
        alt: "Área de Esterilização",
        className: "md:col-span-1 md:row-span-1",
        title: "Biossegurança",
        description: "Rígidos protocolos de esterilização e segurança",
    },
    {
        url: suiteImg.src,
        alt: "Suíte de Recuperação",
        className: "md:col-span-2 md:row-span-1",
        title: "Hospital Dia",
        description: "Recuperação com o conforto e privacidade de uma suíte",
    },
    {
        url: techImg.src,
        alt: "Equipamento Médico",
        className: "md:col-span-1 md:row-span-1",
        title: "Inovação",
        description: "Sistemas avançados de monitoramento",
    },
    {
        url: socialImg.src,
        alt: "Área de Convivência",
        className: "md:col-span-1 md:row-span-1",
        title: "Humanização",
        description: "Espaços pensados para o bem-estar de pacientes e familiares",
    },
    {
        url: infusionImg.src,
        alt: "Sala de Infusão e Conforto",
        className: "md:col-span-1 md:row-span-1",
        title: "Ambiente",
        description: "Espaços projetados para o seu máximo conforto",
    },

    {
        url: extraImg.src,
        alt: "Área Adicional",
        className: "md:col-span-1 md:row-span-1",
        title: "Estrutura",
        description: "Espaços amplos e bem iluminados",
    },
];
---

<section
    class="py-20 md:py-32 bg-white relative overflow-hidden"
    id="estrutura"
>
    <!-- Decorative background blur element -->
    <div
        class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-medical-blue/5 blur-[120px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div
                class="inline-flex items-center gap-2 border border-medical-blue/20 text-medical-blue font-bold px-4 py-1.5 rounded-full text-sm mb-6 bg-white shadow-sm"
            >
                <Camera size={16} /> Estrutura Hospital Dia
            </div>
            <h2
                class="text-3xl md:text-5xl font-bold text-medical-dark font-heading leading-tight mb-6"
            >
                Tecnologia e Conforto para uma <span
                    class="text-medical-blue relative inline-block"
                >
                    Recuperação Ágil
                    <svg
                        class="absolute w-full h-3 -bottom-1 left-0 text-medical-accent/30"
                        viewBox="0 0 100 10"
                        preserveAspectRatio="none"
                    >
                        <path
                            d="M0 5 Q 50 10 100 5"
                            stroke="currentColor"
                            stroke-width="4"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </span>
            </h2>
            <p class="text-lg text-slate-600 leading-relaxed">
                Ambientes projetados para reduzir o estresse hospitalar e
                acelerar sua alta. Salas cirúrgicas com tecnologia de ponta e
                leitos de recuperação desenhados para o seu bem-estar.
            </p>
        </div>

        <!-- Bento Grid Gallery -->
        <div
            class="grid grid-cols-1 md:grid-cols-4 auto-rows-[200px] md:auto-rows-[250px] gap-4 md:gap-6"
        >
            {
                structureImages.map((image, index) => (
                    <div
                        class={`relative group overflow-hidden rounded-3xl ${image.className || "md:col-span-1 md:row-span-1"}`}
                    >
                        <div class="absolute inset-0 bg-medical-dark/20 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none" />
                        <img
                            src={image.url}
                            alt={image.alt}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                            loading="lazy"
                        />

                        <!-- Hover Caption Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-medical-dark/90 via-medical-dark/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 z-20 flex flex-col justify-end p-8 pointer-events-none">
                            <h4 class="text-white font-bold font-heading text-xl translate-y-4 group-hover:translate-y-0 transition-transform duration-300 mb-2">
                                {image.title}
                            </h4>
                            <p class="text-white/80 text-sm translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75">
                                {image.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
