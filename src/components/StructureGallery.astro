---
import { Camera } from "lucide-react";

// Placeholder images for now, the user can replace them later or provide specific ones.
// I'll provide a nice grid layout for ~8 images.
const structureImages = [
    {
        url: "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?q=80&w=2653&auto=format&fit=crop",
        alt: "Fachada do Hospital",
        className: "md:col-span-2 md:row-span-2", // Large feature image
    },
    {
        url: "https://images.unsplash.com/photo-1516549655169-df83a0774514?q=80&w=2670&auto=format&fit=crop",
        alt: "Recepção Moderna",
        className: "md:col-span-1 md:row-span-1",
    },
    {
        url: "https://images.unsplash.com/photo-1551076805-e1869033e561?q=80&w=2670&auto=format&fit=crop",
        alt: "Quarto de Internação",
        className: "md:col-span-1 md:row-span-1",
    },
    {
        url: "https://images.unsplash.com/photo-1512678080530-7760d81faba6?q=80&w=2674&auto=format&fit=crop",
        alt: "Lobby de Espera",
        className: "md:col-span-2 md:row-span-1", // Wide image
    },
    {
        url: "https://images.unsplash.com/photo-1504813184591-01572f98c85f?q=80&w=2671&auto=format&fit=crop",
        alt: "Centro Cirúrgico",
        className: "md:col-span-1 md:row-span-1",
    },
    {
        url: "https://images.unsplash.com/photo-1579684385127-1ef15d508118?q=80&w=2000&auto=format&fit=crop",
        alt: "Consultório de Atendimento",
        className: "md:col-span-1 md:row-span-1",
    },
    {
        url: "https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=2673&auto=format&fit=crop",
        alt: "Equipamentos de Diagnóstico",
        className: "md:col-span-1 md:row-span-1",
    },
    {
        url: "https://images.unsplash.com/photo-1638202993928-7267aad84c31?q=80&w=2574&auto=format&fit=crop",
        alt: "Área Externa",
        className: "md:col-span-1 md:row-span-1",
    },
];
---

<section
    class="py-20 md:py-32 bg-white relative overflow-hidden"
    id="estrutura"
>
    {/* Decorative background blur element */}
    <div
        class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-medical-blue/5 blur-[120px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 md:px-8 max-w-7xl relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div
                class="inline-flex items-center gap-2 border border-medical-blue/20 text-medical-blue font-bold px-4 py-1.5 rounded-full text-sm mb-6 bg-white shadow-sm"
            >
                <Camera size={16} /> Estrutura Hospital Dia
            </div>
            <h2
                class="text-3xl md:text-5xl font-bold text-medical-dark font-heading leading-tight mb-6"
            >
                Tecnologia e Conforto para uma <span
                    class="text-medical-blue relative inline-block"
                >
                    Recuperação Ágil
                    <svg
                        class="absolute w-full h-3 -bottom-1 left-0 text-medical-accent/30"
                        viewBox="0 0 100 10"
                        preserveAspectRatio="none"
                    >
                        <path
                            d="M0 5 Q 50 10 100 5"
                            stroke="currentColor"
                            stroke-width="4"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </span>
            </h2>
            <p class="text-lg text-slate-600 leading-relaxed">
                Ambientes projetados para reduzir o estresse hospitalar e
                acelerar sua alta. Salas cirúrgicas com tecnologia de ponta e
                leitos de recuperação desenhados para o seu bem-estar.
            </p>
        </div>

        {/* Bento Grid Gallery */}
        <div
            class="grid grid-cols-1 md:grid-cols-4 auto-rows-[200px] md:auto-rows-[250px] gap-4 md:gap-6"
        >
            {
                structureImages.map((image, index) => (
                    <div
                        class={`relative group overflow-hidden rounded-3xl ${image.className || "md:col-span-1 md:row-span-1"}`}
                    >
                        <div class="absolute inset-0 bg-medical-dark/20 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none" />
                        <img
                            src={image.url}
                            alt={image.alt}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                            loading="lazy"
                        />

                        {/* Hover Caption Overlay */}
                        <div class="absolute inset-0 bg-gradient-to-t from-medical-dark/80 via-medical-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 flex items-end p-6 pointer-events-none">
                            <span class="text-white font-bold font-heading text-lg translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                                {image.alt}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
