---
import { Phone, Mail, MapPin, Clock, Instagram, Facebook } from "lucide-react";
import logoBranco from "../assets/images/logo-h-branco.png";
---

<footer class="bg-medical-dark text-medical-light pt-20 pb-10">
    <div
        class="container mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 border-b border-medical-light/10 pb-16"
    >
        {/* Brand Section */}
        <div class="space-y-6">
            <img
                src={logoBranco.src}
                alt="Hospital São Lucas"
                class="h-12 w-auto mb-6"
            />
            <p class="text-[15px] leading-relaxed text-blue-100/80">
                O único Hospital Dia da região de Marau. Cirurgias de curta
                permanência, com o conforto de casa e foco total na sua
                recuperação ágil e segura.
            </p>
            <div class="flex gap-3 pt-2">
                <a
                    href="#"
                    class="bg-white/5 hover:bg-medical-accent p-3 rounded-sm transition-colors border border-white/10 hover:border-medical-accent group"
                >
                    <Instagram
                        size={18}
                        className="text-white group-hover:scale-110 transition-transform"
                    />
                </a>
                <a
                    href="#"
                    class="bg-white/5 hover:bg-medical-accent p-3 rounded-sm transition-colors border border-white/10 hover:border-medical-accent group"
                >
                    <Facebook
                        size={18}
                        className="text-white group-hover:scale-110 transition-transform"
                    />
                </a>
            </div>
        </div>

        {/* Links */}
        <div class="space-y-6 lg:ml-8">
            <h3
                class="text-xl font-bold text-white font-heading relative inline-block pb-3"
            >
                Links Rápidos
                <span
                    class="absolute bottom-0 left-0 w-12 h-1 bg-medical-accent"
                ></span>
            </h3>
            <ul class="space-y-3 text-[15px] text-blue-100/80">
                <li>
                    <a
                        href="#"
                        class="hover:text-white transition-colors flex items-center gap-2 before:content-['>'] before:text-medical-accent before:font-bold"
                        >Início</a
                    >
                </li>
                <li>
                    <a
                        href="#especialidades"
                        class="hover:text-white transition-colors flex items-center gap-2 before:content-['>'] before:text-medical-accent before:font-bold"
                        >Especialidades</a
                    >
                </li>
                <li>
                    <a
                        href="#corpo-clinico"
                        class="hover:text-white transition-colors flex items-center gap-2 before:content-['>'] before:text-medical-accent before:font-bold"
                        >Corpo Clínico</a
                    >
                </li>
                <li>
                    <a
                        href="/politica-de-privacidade"
                        class="hover:text-white transition-colors flex items-center gap-2 before:content-['>'] before:text-medical-accent before:font-bold"
                        >Política de Privacidade de Dados</a
                    >
                </li>
                <li>
                    <a
                        href="/ouvidoria"
                        class="hover:text-white transition-colors flex items-center gap-2 before:content-['>'] before:text-medical-accent before:font-bold"
                        >Ouvidoria / SAC</a
                    >
                </li>
            </ul>
        </div>

        {/* Hours */}
        <div class="space-y-6">
            <h3
                class="text-xl font-bold text-white font-heading relative inline-block pb-3"
            >
                Horários
                <span
                    class="absolute bottom-0 left-0 w-12 h-1 bg-medical-accent"
                ></span>
            </h3>
            <div class="text-[15px] text-blue-100/80">
                <p class="mb-4">
                    Funcionamos no modelo <strong class="text-white"
                        >Hospital Dia</strong
                    >.
                </p>
                <ul class="space-y-2">
                    <li
                        class="flex justify-between border-b border-white/10 pb-2"
                    >
                        <span>Segunda - Sexta</span>
                        <span class="text-white font-medium">08:00 - 18:00</span
                        >
                    </li>
                    <li
                        class="flex justify-between border-b border-white/10 pb-2"
                    >
                        <span>Sábados</span>
                        <span class="text-white font-medium">08:00 - 12:00</span
                        >
                    </li>
                    <li
                        class="flex justify-between pb-2 text-medical-accent font-medium"
                    >
                        <span>Domingos</span>
                        <span>Fechado</span>
                    </li>
                </ul>
            </div>
        </div>

        {/* Contact */}
        <div class="space-y-6">
            <h3
                class="text-xl font-bold text-white font-heading relative inline-block pb-3"
            >
                Contato
                <span
                    class="absolute bottom-0 left-0 w-12 h-1 bg-medical-accent"
                ></span>
            </h3>
            <ul class="space-y-4 text-[15px] text-blue-100/80">
                <li class="flex items-start gap-4">
                    <div
                        class="bg-white/5 p-3 rounded-sm border border-white/10"
                    >
                        <MapPin size={20} className="text-medical-accent" />
                    </div>
                    <span class="pt-2 leading-tight"
                        >Avenida Barão do Rio Branco, 1751<br />Centro, Marau –
                        RS</span
                    >
                </li>
                <li class="flex items-center gap-4">
                    <div
                        class="bg-white/5 p-3 rounded-sm border border-white/10"
                    >
                        <Phone size={20} className="text-medical-accent" />
                    </div>
                    <span class="font-bold text-white tracking-wide text-lg"
                        >(54) 3342-9292</span
                    >
                </li>
            </ul>
        </div>
    </div>

    <div
        class="container mx-auto px-6 md:px-12 mt-10 text-sm text-center text-blue-100/50 flex flex-col md:flex-row justify-between items-center gap-4"
    >
        <p>
            &copy; {new Date().getFullYear()} Hospital São Lucas. Todos os direitos
            reservados. | <a href="/politica-de-privacidade" class="hover:text-white underline-offset-4 hover:underline">Política de Privacidade</a> | <a href="/ouvidoria" class="hover:text-white underline-offset-4 hover:underline">Ouvidoria</a>
        </p>
        <p>
            Desenvolvido por <a
                href="#"
                class="text-white hover:text-medical-accent font-medium transition-colors"
                >Naveo</a
            >
        </p>
    </div>
</footer>
