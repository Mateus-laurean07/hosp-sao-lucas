---
// components/DiagnosticCTA.astro
import cdLogo from "../assets/cd-logo.png";
---

<section class="w-full bg-slate-50/50 relative py-12 md:py-24 overflow-hidden">
    <!-- Fluid background elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-[#00a3e0]/5 blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-[#2298f6]/5 blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>
    <div
        class="max-w-[1920px] w-full md:w-[96%] mx-auto relative overflow-hidden flex flex-col md:flex-row min-h-[500px] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.08)] bg-white md:rounded-[3rem] border border-slate-100 reveal-on-scroll"
    >
        <!-- Right Side Image (Background element underneath the blue shape on desktop) -->
        <div
            class="md:absolute right-0 top-0 w-full md:w-[50%] lg:w-[50%] h-[350px] md:h-full z-0 order-2 md:order-1 flex items-center justify-center p-6 lg:p-8 bg-white"
        >
            <img
                src={cdLogo.src}
                alt="Centro de Diagnóstico"
                class="w-full max-w-[550px] lg:max-w-[650px] h-auto object-contain drop-shadow-xl float-animation"
            />
        </div>

        <!-- Left Side White Panel -->
        <div
            class="relative md:absolute left-0 top-0 w-full md:w-[50%] lg:w-[50%] h-full z-10 flex flex-col justify-center overflow-hidden bg-white/80 backdrop-blur-sm order-1 md:order-2"
        >




            <!-- Content - Old Copy Restored -->
            <div
                class="relative z-20 w-full p-8 md:p-12 lg:p-16 flex flex-col justify-center max-w-2xl"
            >
                <div
                    class="inline-flex py-1 px-4 rounded-full bg-[#2298f6]/10 text-[#2298f6] text-sm font-semibold mb-6 shadow-sm w-fit border border-[#2298f6]/20"
                >
                    Exames Sem Sair do Hospital
                </div>

                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#00a3e0] mb-4 leading-[1.1]"
                >
                    Diagnóstico Ágil <br /> e Altamente Preciso
                </h2>

                <p
                    class="text-slate-600 text-lg md:text-xl lg:text-2xl mb-6 font-light leading-snug"
                >
                    Em parceria com o <strong class="font-semibold text-[#00a3e0]"
                        >Centro de Diagnóstico</strong
                    > – Apoiado pela excelência Einstein. Tudo que você precisa para
                    sua cirurgia ou consulta no mesmo lugar.
                </p>

                <div class="flex mt-6">
                    <a
                        href="https://centrodediagnostico.com.br/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 bg-[#2298f6] text-white rounded-lg font-medium hover:bg-[#1a8bea] transition-colors shadow-sm text-base"
                    >
                        Agendar Seu Exame
                        <svg
                            class="ml-2 w-5 h-5 flex-shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <style>
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .reveal-on-scroll.active {
            opacity: 1;
            transform: translateY(0);
        }

        .float-animation {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>

    <script>
        const observerOptions = {
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, observerOptions);

        document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
    </script>
</section>
