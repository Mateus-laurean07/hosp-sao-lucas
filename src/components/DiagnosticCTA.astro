---
// components/DiagnosticCTA.astro
import parceriaAlbert from "../assets/parceria_albert.webp";
---

<section class="w-full bg-white relative py-12 md:py-24">
    <div
        class="max-w-[1920px] w-full md:w-[96%] mx-auto relative overflow-hidden flex flex-col md:flex-row min-h-[500px] shadow-[0_20px_50px_rgba(0,0,0,0.1)] bg-white md:rounded-[2.5rem]"
    >
        <!-- Right Side Image (Background element underneath the blue shape on desktop) -->
        <div
            class="md:absolute right-0 top-0 w-full md:w-[60%] lg:w-[55%] h-[350px] md:h-full z-0 order-2 md:order-1"
        >
            <img
                src={parceriaAlbert.src}
                alt="Centro de Diagnóstico Parceria"
                class="w-full h-full object-cover object-[center_30%]"
            />
        </div>

        <!-- Left Side Blue Panel overlaying the image -->
        <div
            class="relative md:absolute left-0 top-0 w-full md:w-[55%] lg:w-[60%] h-full z-10 flex flex-col justify-center overflow-hidden bg-[#598ab1] order-1 md:order-2"
        >
            <!-- Decorative Rings inside the blue panel -->
            <div
                class="absolute top-[50%] md:top-[60%] left-[20%] md:left-[-10%] lg:left-[5%] -translate-x-1/2 md:translate-x-0 -translate-y-1/2 w-[800px] h-[800px] rounded-full border-[60px] border-white/5 opacity-50 pointer-events-none mix-blend-overlay"
            >
            </div>
            <div
                class="absolute top-[50%] md:top-[60%] left-[20%] md:left-[-10%] lg:left-[15%] -translate-x-1/2 md:translate-x-0 -translate-y-1/2 w-[1200px] h-[1200px] rounded-full border-[80px] border-white/5 opacity-50 pointer-events-none mix-blend-overlay"
            >
            </div>

            <!-- SVG Curve at the right boundary to overlap the image -->
            <svg
                class="hidden md:block absolute right-[-1px] top-0 h-full w-24 lg:w-32 translate-x-[99%] text-[#598ab1]"
                preserveAspectRatio="none"
                viewBox="0 0 100 100"
                fill="currentColor"
            >
                <path d="M0,0 C100,50 100,50 0,100" stroke="none"></path>
            </svg>

            <!-- Content - Old Copy Restored -->
            <div
                class="relative z-20 w-full p-8 md:p-12 lg:p-16 xl:p-24 flex flex-col justify-center max-w-4xl"
            >
                <div
                    class="inline-flex py-1 px-4 rounded-full bg-[#0b1021]/30 text-white text-sm font-semibold mb-6 shadow-sm w-fit border border-white/20 backdrop-blur-sm"
                >
                    Exames Sem Sair do Hospital
                </div>

                <h2
                    class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight"
                >
                    Diagnóstico Ágil <br /> e Altamente Preciso
                </h2>

                <p
                    class="text-white/90 text-lg md:text-xl lg:text-2xl mb-10 font-light leading-relaxed"
                >
                    Em parceria com o <strong class="font-semibold text-white"
                        >Centro de Diagnóstico</strong
                    > – Apoiado pela excelência Einstein. Tudo que você precisa para
                    sua cirurgia ou consulta no mesmo lugar.
                </p>

                <div class="flex mt-6">
                    <a
                        href="https://centrodediagnostico.com.br/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 bg-[#2298f6] text-white rounded-lg font-medium hover:bg-[#1a8bea] transition-colors shadow-sm text-base"
                    >
                        Agendar Seu Exame
                        <svg
                            class="ml-2 w-5 h-5 flex-shrink-0"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
