---
import { ArrowRight } from "lucide-react";
---

<section class="relative pt-4 pb-12 px-4 md:px-6 bg-surface-gray">
    <div
        class="max-w-[1600px] mx-auto relative rounded-[32px] overflow-hidden min-h-[600px] md:min-h-[800px] flex items-center shadow-lg bg-medical-dark"
    >
        {/* Background Image */}
        <div class="absolute inset-0 z-0">
            <img
                src="/images/medzin-hero-doctor.png"
                alt="Médica empática conversando com paciente"
                class="w-full h-full object-cover object-center opacity-80 mix-blend-overlay"
            />
            <div
                class="absolute inset-0 bg-gradient-to-r from-[#8ca8ca]/95 via-[#8ca8ca]/70 to-[#8ca8ca]/10"
            >
            </div>
        </div>

        {/* Content */}
        <div class="relative z-10 w-full px-8 md:px-16 lg:px-24">
            <div class="max-w-2xl">
                <div
                    class="inline-block bg-[#0284c7] text-white font-bold text-sm tracking-wider px-4 py-1.5 rounded-full mb-6"
                >
                    Referência em Saúde em Marau
                </div>

                <h1
                    class="text-4xl md:text-6xl lg:text-7xl font-bold text-white font-heading leading-[1.1] mb-6"
                >
                    Excelência Médica e <br />Cuidado Completo
                </h1>

                <p
                    class="text-lg md:text-xl text-white/90 mb-10 leading-relaxed font-medium max-w-xl"
                >
                    Estrutura moderna, tecnologia de ponta e um corpo clínico
                    altamente especializado pronto para cuidar de você e da sua
                    família com a excelência que merecem.
                </p>

                <a
                    href="#especialidades"
                    class="inline-flex items-center gap-2 bg-[#0284c7] hover:bg-[#0369a1] text-white px-8 py-4 rounded-md font-bold transition-all text-lg shadow-lg group"
                >
                    Encontrar Médico
                </a>
            </div>
        </div>
    </div>
</section>
